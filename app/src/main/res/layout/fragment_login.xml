<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/xui_config_color_background"
    android:orientation="vertical">

    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        app:srcCompat="@drawable/school_assistant" />

    <com.scwang.smart.refresh.layout.SmartRefreshLayout
        style="@style/PullDownStyle"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            style="@style/ScrollViewStyle"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <com.xuexiang.xui.widget.layout.XUIFrameLayout
                            style="@style/XUILayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="start|center_vertical"
                                android:tint="?attr/colorAccent"
                                app:srcCompat="@drawable/ic_phone" />

                            <com.xuexiang.xui.widget.edittext.materialedittext.MaterialEditText
                                android:id="@+id/et_phone_number"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="36dp"
                                android:hint="@string/inputnum"
                                android:inputType="number"
                                app:met_clearButton="true"
                                app:met_errorMessage="@string/tip_phone_number_error"
                                app:met_floatingLabel="normal"
                                app:met_floatingLabelText="@string/title_phone_number"
                                app:met_hideUnderline="true"
                                app:met_maxCharacters="11"
                                app:met_regexp="@string/regex_phone_number" />
                        </com.xuexiang.xui.widget.layout.XUIFrameLayout>

                        <com.xuexiang.xui.widget.layout.XUIFrameLayout
                            android:id="@+id/fl_verify_code"
                            style="@style/XUILayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="36dp">

                            <androidx.appcompat.widget.AppCompatImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="start|center_vertical"
                                android:tint="?attr/colorAccent"
                                app:srcCompat="@drawable/yanzhengma" />

                            <com.xuexiang.xui.widget.edittext.materialedittext.MaterialEditText
                                android:id="@+id/et_password"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="36dp"
                                android:layout_marginEnd="40dp"
                                android:hint="@string/please_input_pwd"
                                android:inputType="textPassword"
                                app:met_clearButton="false"
                                app:met_errorMessage="@string/tip_password_error"
                                app:met_floatingLabel="normal"
                                app:met_floatingLabelText="@string/please_input_pwd"
                                app:met_hideUnderline="true"
                                app:met_maxCharacters="18"
                                app:met_regexp="@string/regex_password" />

                            <androidx.appcompat.widget.AppCompatImageView
                                android:id="@+id/iv_pwd_toggle"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="8dp"
                                android:padding="4dp"
                                android:tint="?attr/colorAccent"
                                app:srcCompat="@drawable/ic_eye_closed" /> </com.xuexiang.xui.widget.layout.XUIFrameLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp">

                            <com.xuexiang.xui.widget.alpha.XUIAlphaTextView
                                android:id="@+id/tv_reg"
                                style="@style/TextStyle.Explain"
                                android:layout_alignParentStart="true"
                                android:padding="5dp"
                                android:text="我要注册"
                                android:textColor="@color/xui_config_color_primary_text" />

                            <com.xuexiang.xui.widget.alpha.XUIAlphaTextView
                                android:id="@+id/tv_forget_password"
                                style="@style/TextStyle.Explain"
                                android:layout_alignParentEnd="true"
                                android:padding="5dp"
                                android:text="忘记密码"
                                android:textColor="@color/xui_config_color_primary_text" />
                        </RelativeLayout>

                        <com.xuexiang.xui.widget.textview.supertextview.SuperButton
                            android:id="@+id/btn_login"
                            style="@style/SuperButton.Primary.Login"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="25dp"
                            android:text="@string/title_login_register" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cb_protocol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:scaleX="0.7"
                        android:scaleY="0.7" />

                    <TextView
                        style="@style/TextStyle.Explain"
                        android:layout_width="wrap_content"
                        android:text="@string/agree_protocol"
                        android:textColor="@color/xui_config_color_primary_text" />

                    <com.xuexiang.xui.widget.alpha.XUIAlphaTextView
                        android:id="@+id/tv_user_protocol"
                        style="@style/TextStyle.Explain"
                        android:layout_width="wrap_content"
                        android:text="@string/title_user_protocol"
                        android:textColor="?attr/colorAccent" />

                    <TextView
                        style="@style/TextStyle.Explain"
                        android:layout_width="wrap_content"
                        android:text="@string/lab_and"
                        android:textColor="@color/xui_config_color_primary_text" />

                    <com.xuexiang.xui.widget.alpha.XUIAlphaTextView
                        android:id="@+id/tv_privacy_protocol"
                        style="@style/TextStyle.Explain"
                        android:layout_width="wrap_content"
                        android:text="@string/title_privacy_protocol"
                        android:textColor="?attr/colorAccent" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.scwang.smart.refresh.layout.SmartRefreshLayout>

</LinearLayout>